# Supabase (required for auth and data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for server-side admin operations that bypass RLS (e.g. assigning roles)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth app (register once at console.cloud.google.com — shared across all clients)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Public app URL (used for Google OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Gemini AI (for post generation and cover image generation via Imagen 3)
GEMINI_API_KEY=your-gemini-api-key

# Scheduler secret — set a random string to protect /api/scheduler from unauthorised calls
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret
